# OptimalFit public coach server (tunnel). Copy to .env.coach and fill in.
# Same values go: (1) into the server via tools/start-coach-server.sh, and
# (2) baked into the app build via `node tools/bake-coach-config.mjs`.
OPTIMALFIT_PUBLIC_HOST=your-host.tailnet.ts.net
OPTIMALFIT_ACCESS_KEY=generate-with: python3 -c "import secrets;print(secrets.token_urlsafe(24))"
