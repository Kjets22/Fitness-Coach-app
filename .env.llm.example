# OptimalFit — LLM API-key mode (optional)
#
# By DEFAULT the AI features (Coach, food-photo macros, physique analysis) run
# through the Claude Code CLI on this computer — your own Claude subscription,
# zero per-token cost. You do NOT need this file for that.
#
# To route the AI through a PAID Anthropic API key instead (so it no longer
# uses your personal Claude subscription): copy this file to ".env.llm" in the
# same folder as serve.py and fill in your key. serve.py picks it up on the
# next request — no restart. Delete ".env.llm" to switch back to the CLI.
#
#   cp .env.llm.example .env.llm   &&   edit .env.llm
#
# ".env.llm" is gitignored — your key never leaves this machine.

# Your Anthropic API key from https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional — which model to use. Default is claude-opus-4-8 (most capable).
# For lower cost per request, claude-sonnet-5 or claude-haiku-4-5 also work.
# OPTIMALFIT_LLM_MODEL=claude-opus-4-8
