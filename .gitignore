# ============================================================
# OptimalFit — repo hygiene for the future GitHub repo.
# CRITICAL: signing material must NEVER be committed. The cloud
# workflows receive the keystore via GitHub Actions secrets.
# NOTE: gitignore comments must be on their OWN line (a trailing
# "# ..." would become part of the pattern).
# ============================================================

# --- SECRETS: Supabase (Phase 3 social backend) ---
# Service-role key, personal access token and DB password live ONLY
# in the local env file below. The publishable anon key is the only
# Supabase credential allowed inside client code.
.env.supabase
.env
*.env.local
supabase/.temp/
# Backend test-user credentials (created via the Auth Admin API; never commit)
.env.reviewer
.env.test-users

# --- SECRETS: Android signing (see dist/SIGNING-INFO.txt) ---
dist/*.keystore
dist/keystore.properties
dist/SIGNING-INFO.txt

# Built artifacts (regenerate via gradle / the Actions workflows)
dist/*.apk
dist/*.aab
dist/*.ipa

# Apple signing material, if ever exported here
*.p12
*.mobileprovision
*.p8

# --- Node / Capacitor ---
node_modules/

# GENERATED by scripts/copy-web.js — never edit, never commit
native/www/

# --- Android build output (machine-specific / generated) ---
native/android/.gradle/
native/android/build/
native/android/app/build/
native/android/capacitor-cordova-android-plugins/build/
native/android/local.properties
# GENERATED by cap sync (CI regenerates before building)
native/android/app/src/main/assets/public/
native/android/app/src/main/assets/capacitor.config.json
native/android/app/src/main/assets/capacitor.plugins.json

# --- iOS build output (generated) ---
native/ios/App/build/
native/ios/App/output/
native/ios/DerivedData/
# GENERATED by cap sync (CI regenerates before building)
native/ios/App/App/public/
native/ios/App/App/capacitor.config.json
xcuserdata/

# --- Python / misc ---
__pycache__/
*.pyc
.DS_Store
Thumbs.db

# Persona demo accounts (Part A populate; created via Auth Admin API)
.env.personas
